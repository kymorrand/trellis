# Trellis Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# === Model Providers ===

# Anthropic (primary cloud model)
IVY_ANTHROPIC_KEY=your-anthropic-api-key-here

# Ollama (local inference — no key needed, just the endpoint)
IVY_OLLAMA_URL=http://localhost:11434

# LiteLLM proxy (unified routing)
IVY_LITELLM_URL=http://localhost:4000

# === Communication ===

# Discord bot token
IVY_DISCORD_TOKEN=your-discord-bot-token-here
IVY_DISCORD_GUILD_ID=your-private-server-id
IVY_DISCORD_ALLOWED_USER_ID=your-discord-user-id

# === Integrations ===

# Google Calendar (read-only OAuth)
IVY_GOOGLE_CREDENTIALS_PATH=./credentials/google-oauth.json

# Linear API
IVY_LINEAR_API_KEY_MORRANDMORE=your-linear-key-here
IVY_LINEAR_API_KEY_MF=your-mf-linear-key-here

# GitHub (for vault backup)
IVY_GITHUB_TOKEN=your-github-token-here

# === Runtime Config ===

# Path to the Obsidian vault
IVY_VAULT_PATH=/home/kyle/ivy-vault

# Monthly cloud API budget cap (USD)
IVY_BUDGET_MONTHLY=100.00

# Log level (DEBUG, INFO, WARNING, ERROR)
IVY_LOG_LEVEL=INFO
